{
  "expo": {
    "name": "SafeHaven",
    "slug": "safehaven-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0038A8"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.safehaven.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SafeHaven needs your location to show nearby evacuation centers and send location-based disaster alerts.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SafeHaven needs your location to send you relevant disaster alerts even when the app is in the background."
      }
    },
    "android": {
      "icon": "./assets/logo.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#0038A8"
      },
      "package": "com.safehaven.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAOVYRIgupAurZup5y1PRh8Ismb1A3lLao"
        }
      }
    },
    "plugins": [
      "expo-location",
      "expo-image-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "658ac31a-7930-47e9-9adc-8126ed6a438a"
      }
    }
  }
}
